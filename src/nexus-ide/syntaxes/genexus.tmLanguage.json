{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmLanguage.json",
	"name": "GeneXus",
	"patterns": [
		{ "include": "#comments" },
		{ "include": "#keywords" },
		{ "include": "#operators" },
		{ "include": "#variables" },
		{ "include": "#strings" },
		{ "include": "#numbers" }
	],
	"repository": {
		"keywords": {
			"patterns": [{
				"name": "keyword.control",
				"match": "(?i)\\b(for each|endfor|where|when|defined by|if|else|endif|do case|case|otherwise|endcase|do while|endwhile|sub|endsub|new|when duplicate|endnew|delete|commit|rollback|call|return|exit|print|using|in|by)\\b"
			}]
		},
		"operators": {
			"patterns": [{
				"name": "keyword.operator.logical",
				"match": "(?i)\\b(and|or|not)\\b"
			}, {
				"name": "keyword.operator.assignment",
				"match": "=|\\+=|-="
			}]
		},
		"variables": {
			"patterns": [{
				"name": "variable.other.readwrite",
				"match": "(&[a-zA-Z_][a-zA-Z0-9_]*)"
			}]
		},
		"strings": {
			"name": "string.quoted.double",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{ "name": "constant.character.escape", "match": "\\\\." }
			]
		},
		"numbers": {
			"patterns": [{
				"name": "constant.numeric",
				"match": "\\b[0-9]+(\\.[0-9]+)?\\b"
			}]
		},
		"comments": {
			"patterns": [
				{ "name": "comment.line.double-slash", "match": "//.*$" },
				{ "name": "comment.block", "begin": "/\\*", "end": "\\*/" }
			]
		}
	},
	"scopeName": "source.gx"
}
