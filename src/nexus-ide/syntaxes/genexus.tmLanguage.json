{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmLanguage.json",
	"name": "GeneXus",
	"patterns": [
		{ "include": "#comments" },
		{ "include": "#strings" },
		{ "include": "#keywords" },
		{ "include": "#functions" },
		{ "include": "#variables" },
		{ "include": "#operators" },
		{ "include": "#numbers" }
	],
	"repository": {
		"keywords": {
			"patterns": [{
				"name": "keyword.control.gx",
				"match": "(?i)\\b(?:event|endevent|for each|endfor|where|when|defined by|if|else|endif|do case|case|otherwise|endcase|do while|endwhile|sub|endsub|new|when duplicate|endnew|delete|commit|rollback|call|return|exit|print|using|in|by|do|sub|endsub)\\b"
			}, {
				"name": "keyword.other.gx",
				"match": "(?i)\\b(?:default|none|null|empty|true|false|unknown)\\b"
			}]
		},
		"functions": {
			"patterns": [{
				"name": "support.function.gx",
				"match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\()"
			}, {
				"name": "support.function.gx",
				"match": "\\.[a-zA-Z_][a-zA-Z0-9_]*\\b"
			}]
		},
		"operators": {
			"patterns": [{
				"name": "keyword.operator.logical.gx",
				"match": "(?i)\\b(?:and|or|not)\\b"
			}, {
				"name": "keyword.operator.assignment.gx",
				"match": "=|\\+=|-="
			}, {
				"name": "keyword.operator.comparison.gx",
				"match": "==|!=|<>|<|>|<=|>="
			}]
		},
		"variables": {
			"patterns": [{
				"name": "variable.other.gx",
				"match": "&[a-zA-Z_][a-zA-Z0-9_]*"
			}]
		},
		"strings": {
			"patterns": [{
				"name": "string.quoted.double.gx",
				"begin": "\"",
				"end": "\"",
				"patterns": [
					{ "name": "constant.character.escape.gx", "match": "\\\\." }
				]
			}, {
				"name": "string.quoted.single.gx",
				"begin": "'",
				"end": "'",
				"patterns": [
					{ "name": "constant.character.escape.gx", "match": "\\\\." }
				]
			}]
		},
		"numbers": {
			"patterns": [{
				"name": "constant.numeric.gx",
				"match": "\\b[0-9]+(?:\\.[0-9]+)?\\b"
			}]
		},
		"comments": {
			"patterns": [
				{ "name": "comment.line.double-slash.gx", "match": "//.*$" },
				{ "name": "comment.block.gx", "begin": "/\\*", "end": "\\*/" }
			]
		}
	},
	"scopeName": "source.gx"
}
