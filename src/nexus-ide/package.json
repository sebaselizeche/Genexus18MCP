{
  "name": "nexus-ide",
  "displayName": "Nexus IDE (GeneXus)",
  "description": "Lightweight GeneXus IDE for VS Code powered by MCP",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onFileSystem:genexus",
    "workspaceContains:**/*.gx"
  ],
  "enabledApiProposals": [
    "fileSearchProvider"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "genexus",
          "title": "GeneXus",
          "icon": "resources/genexus-logo.svg"
        }
      ]
    },
    "views": {
      "genexus": [
        {
          "id": "genexusExplorer",
          "name": "KB Explorer",
          "icon": "$(file-submodule)"
        },
        {
          "id": "genexusActions",
          "name": "Action Center",
          "icon": "$(rocket)"
        }
      ]
    },
    "languages": [{
      "id": "genexus",
      "aliases": ["GeneXus", "gx"],
      "extensions": [".gx"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "genexus",
      "scopeName": "source.gx",
      "path": "./syntaxes/genexus.tmLanguage.json"
    }],
    "iconThemes": [
      {
        "id": "genexus-icons",
        "label": "GeneXus Icons",
        "path": "./genexus-icons.json"
      }
    ],
    "themes": [
      {
        "id": "genexus-classic",
        "label": "GeneXus Classic",
        "uiTheme": "vs",
        "path": "./themes/genexus-classic.json"
      },
      {
        "id": "genexus-dark",
        "label": "GeneXus Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/genexus-dark.json"
      }
    ],
    "commands": [
      {
        "command": "nexus-ide.openKb",
        "title": "GeneXus: Open KB",
        "category": "GeneXus"
      },
      {
        "command": "nexus-ide.indexKb",
        "title": "GeneXus: Index KB",
        "category": "GeneXus"
      },
      {
        "command": "nexus-ide.newObject",
        "title": "GeneXus: New Object",
        "category": "GeneXus",
        "icon": "$(add)"
      },
      {
        "command": "nexus-ide.renameAttribute",
        "title": "GeneXus: Rename Attribute (Global)",
        "category": "GeneXus",
        "icon": "$(edit)"
      },
      {
        "command": "nexus-ide.buildObject",
        "title": "GeneXus: Build with this only",
        "category": "GeneXus",
        "icon": "$(play)"
      },
      {
        "command": "nexus-ide.rebuildAll",
        "title": "GeneXus: Rebuild All",
        "category": "GeneXus",
        "icon": "$(zap)"
      },
      {
        "command": "nexus-ide.generateDiagram",
        "title": "GeneXus: Generate Diagram (Mermaid)",
        "category": "GeneXus",
        "icon": "$(graph)"
      },
      {
        "command": "nexus-ide.autoFix",
        "title": "GeneXus: Auto-Fix Build Errors (AI)",
        "category": "GeneXus",
        "icon": "$(beaker)"
      },
      {
        "command": "nexus-ide.refreshTree",
        "title": "GeneXus: Refresh Tree",
        "category": "GeneXus"
      },
      {
        "command": "nexus-ide.forceSave",
        "title": "GeneXus: Force Save (Ignore Bloqueios)",
        "category": "GeneXus"
      },
      {
        "command": "nexus-ide.switchPart.Source",
        "title": "Source"
      },
      {
        "command": "nexus-ide.switchPart.Rules",
        "title": "Rules"
      },
      {
        "command": "nexus-ide.switchPart.Variables",
        "title": "Variables"
      },
      {
        "command": "nexus-ide.switchPart.Events",
        "title": "Events"
      },
      {
        "command": "nexus-ide.switchPart.Layout",
        "title": "Layout"
      },
      {
        "command": "nexus-ide.copyMcpConfig",
        "title": "GeneXus: Copy MCP Config for Copilot/Claude",
        "category": "GeneXus"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "nexus-ide.buildObject",
          "when": "view == genexusExplorer && viewItem =~ /gx_(procedure|transaction|webpanel|sdpanel|dataprovider)/",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "nexus-ide.buildObject",
          "when": "resourceScheme == genexus",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "command": "nexus-ide.buildObject",
          "when": "resourceScheme == genexus",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "nexus-ide.newObject",
          "when": "view == genexusExplorer || view == genexusActions",
          "group": "navigation"
        },
        {
          "command": "nexus-ide.openKb",
          "when": "view == genexusExplorer",
          "group": "navigation"
        },
        {
          "command": "nexus-ide.refreshTree",
          "when": "view == genexusExplorer",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "nexus-ide.switchPart.Source",
          "group": "navigation@1",
          "when": "resourceScheme == genexus"
        },
        {
          "command": "nexus-ide.switchPart.Rules",
          "group": "navigation@2",
          "when": "resourceScheme == genexus"
        },
        {
          "command": "nexus-ide.switchPart.Events",
          "group": "navigation@3",
          "when": "resourceScheme == genexus && resourcePath =~ /\\/(WebPanel|Transaction|SDPanel)\\//"
        },
        {
          "command": "nexus-ide.switchPart.Variables",
          "group": "navigation@4",
          "when": "resourceScheme == genexus"
        },
        {
          "command": "nexus-ide.switchPart.Layout",
          "group": "navigation@5",
          "when": "resourceScheme == genexus && resourcePath =~ /\\/(WebPanel|Transaction|SDPanel)\\//"
        }
      ]
    },
    "configuration": {
      "title": "GeneXus Nexus IDE",
      "properties": {
        "genexus.kbPath": {
          "type": "string",
          "default": "",
          "description": "Path to the GeneXus Knowledge Base."
        },
        "genexus.installationPath": {
          "type": "string",
          "default": "C:\\Program Files (x86)\\GeneXus\\GeneXus18",
          "description": "Path to the GeneXus 18 installation directory."
        },
        "genexus.mcpPort": {
          "type": "number",
          "default": 5000,
          "description": "Port where the MCP Gateway will run."
        },
        "genexus.autoStartBackend": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the MCP backend when the extension activates."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "typescript": "^5.3.2"
  }
}
