{
  "name": "nexus-ide",
  "displayName": "Nexus IDE (GeneXus)",
  "description": "Lightweight GeneXus IDE for VS Code powered by MCP",
  "version": "0.0.1",
  "publisher": "lennix1337",
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onFileSystem:gxkb18",
    "onStartupFinished",
    "onCommand:nexus-ide.openKb",
    "onCommand:nexus-ide.addKbFolder"
  ],
  "enabledApiProposals": [
    "fileSearchProvider",
    "textSearchProvider"
  ],
  "capabilities": {
    "virtualWorkspaces": true,
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "genexus",
          "title": "GeneXus",
          "icon": "resources/genexus-logo.svg"
        }
      ]
    },
    "views": {
      "genexus": [
        {
          "id": "genexusExplorer",
          "name": "KB Explorer",
          "icon": "$(file-submodule)"
        },
        {
          "id": "genexusActions",
          "name": "Action Center",
          "icon": "$(rocket)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "genexusExplorer",
        "contents": "Welcome to Nexus IDE for GeneXus. To start, please open your Knowledge Base.\n[Open KB](command:nexus-ide.openKb)"
      }
    ],
    "languages": [
      {
        "id": "genexus",
        "aliases": [
          "GeneXus",
          "gx"
        ],
        "extensions": [
          ".gx"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "genexus",
        "scopeName": "source.gx",
        "path": "./syntaxes/genexus.tmLanguage.json"
      }
    ],
    "iconThemes": [
      {
        "id": "genexus-icons",
        "label": "GeneXus Icons",
        "path": "./genexus-icons.json"
      }
    ],
    "languageModelTools": [
      {
        "name": "genexus_search",
        "displayName": "GeneXus Search",
        "toolReferenceName": "genexus_search",
        "canBeReferencedInPrompt": true,
        "modelDescription": "Search for objects in the GeneXus Knowledge Base by name or type.",
        "userDescription": "Search GeneXus KB",
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "The search query (e.g., 'Customer', 'type:Procedure')"
            }
          },
          "required": [
            "query"
          ]
        }
      }
    ],
    "fileSystemProvider": [
      {
        "scheme": "gxkb18"
      }
    ],
    "themes": [
      {
        "id": "genexus-classic",
        "label": "GeneXus Classic",
        "uiTheme": "vs",
        "path": "./themes/genexus-classic.json"
      },
      {
        "id": "genexus-dark",
        "label": "GeneXus Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/genexus-dark.json"
      }
    ],
    "commands": [
      {
        "command": "nexus-ide.openKb",
        "title": "GeneXus: Open KB",
        "category": "GeneXus"
      },
      {
        "command": "nexus-ide.addKbFolder",
        "title": "GeneXus: Force Add KB Folder",
        "category": "GeneXus"
      },
      {
        "command": "nexus-ide.refreshFilesystem",
        "title": "GeneXus: Refresh KB Explorer",
        "category": "GeneXus",
        "icon": "$(refresh)"
      },
      {
        "command": "nexus-ide.indexKb",
        "title": "GeneXus: Index KB",
        "category": "GeneXus"
      },
      {
        "command": "nexus-ide.newObject",
        "title": "GeneXus: New Object",
        "category": "GeneXus",
        "icon": "$(add)"
      },
      {
        "command": "nexus-ide.renameAttribute",
        "title": "GeneXus: Rename Attribute (Global)",
        "category": "GeneXus",
        "icon": "$(edit)"
      },
      {
        "command": "nexus-ide.buildObject",
        "title": "GeneXus: Build with this only",
        "category": "GeneXus",
        "icon": "$(play)"
      },
      {
        "command": "nexus-ide.rebuildAll",
        "title": "GeneXus: Rebuild All",
        "category": "GeneXus",
        "icon": "$(zap)"
      },
      {
        "command": "nexus-ide.generateDiagram",
        "title": "GeneXus: Generate Diagram (Mermaid)",
        "category": "GeneXus",
        "icon": "$(graph)"
      },
      {
        "command": "nexus-ide.autoFix",
        "title": "GeneXus: Auto-Fix Build Errors (AI)",
        "category": "GeneXus",
        "icon": "$(beaker)"
      },
      {
        "command": "nexus-ide.refreshTree",
        "title": "GeneXus: Refresh Tree",
        "category": "GeneXus"
      },
      {
        "command": "nexus-ide.forceSave",
        "title": "GeneXus: Force Save (Ignore Bloqueios)",
        "category": "GeneXus"
      },
      {
        "command": "nexus-ide.switchPart.Structure",
        "title": "Structure",
        "icon": "$(layout)"
      },
      {
        "command": "nexus-ide.switchPart.Structure.active",
        "title": "Structure",
        "icon": "$(check)"
      },
      {
        "command": "nexus-ide.switchPart.Source",
        "title": "Source",
        "icon": "$(file-code)"
      },
      {
        "command": "nexus-ide.switchPart.Source.active",
        "title": "Source",
        "icon": "$(check)"
      },
      {
        "command": "nexus-ide.switchPart.Rules",
        "title": "Rules",
        "icon": "$(list-unordered)"
      },
      {
        "command": "nexus-ide.switchPart.Rules.active",
        "title": "Rules",
        "icon": "$(check)"
      },
      {
        "command": "nexus-ide.switchPart.Variables",
        "title": "Variables",
        "icon": "$(symbol-variable)"
      },
      {
        "command": "nexus-ide.switchPart.Variables.active",
        "title": "Variables",
        "icon": "$(check)"
      },
      {
        "command": "nexus-ide.switchPart.Events",
        "title": "Events",
        "icon": "$(zap)"
      },
      {
        "command": "nexus-ide.switchPart.Events.active",
        "title": "Events",
        "icon": "$(check)"
      },
      {
        "command": "nexus-ide.switchPart.Layout",
        "title": "Layout",
        "icon": "$(browser)"
      },
      {
        "command": "nexus-ide.switchPart.Layout.active",
        "title": "Layout",
        "icon": "$(check)"
      },
      {
        "command": "nexus-ide.switchPart.Indexes",
        "title": "Indexes"
      },
      {
        "command": "nexus-ide.switchPart.Indexes.active",
        "title": "Indexes",
        "icon": "$(check)"
      },
      {
        "command": "nexus-ide.copyMcpConfig",
        "title": "GeneXus: Copy MCP Config for Copilot/Claude",
        "category": "GeneXus"
      },
      {
        "command": "nexus-ide.showVisualStructure",
        "title": "GeneXus: Show Visual Structure",
        "category": "GeneXus",
        "icon": "$(list-tree)"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "nexus-ide.buildObject",
          "when": "view == genexusExplorer && viewItem =~ /gx_(procedure|transaction|webpanel|sdpanel|dataprovider)/",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "nexus-ide.buildObject",
          "when": "resourceScheme == gxkb18",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "command": "nexus-ide.buildObject",
          "when": "resourceScheme == gxkb18",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "nexus-ide.openKb",
          "when": "view == genexusExplorer",
          "group": "navigation"
        },
        {
          "command": "nexus-ide.refreshTree",
          "when": "view == genexusExplorer",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "nexus-ide.switchPart.Structure",
          "group": "navigation@1",
          "when": "resourceScheme == gxkb18 && resourcePath =~ /\\/(SDT|StructuredDataType|Transaction|Table)\\// && genexus.activePart != Structure"
        },
        {
          "command": "nexus-ide.switchPart.Structure.active",
          "group": "navigation@1",
          "when": "resourceScheme == gxkb18 && resourcePath =~ /\\/(SDT|StructuredDataType|Transaction|Table)\\// && genexus.activePart == Structure"
        },
        {
          "command": "nexus-ide.switchPart.Source",
          "group": "navigation@2",
          "when": "resourceScheme == gxkb18 && !(resourcePath =~ /\\/(Transaction|WebPanel|SDPanel|Table)\\//) && genexus.activePart != Source"
        },
        {
          "command": "nexus-ide.switchPart.Source.active",
          "group": "navigation@2",
          "when": "resourceScheme == gxkb18 && !(resourcePath =~ /\\/(Transaction|WebPanel|SDPanel|Table)\\//) && genexus.activePart == Source"
        },
        {
          "command": "nexus-ide.switchPart.Rules",
          "group": "navigation@3",
          "when": "resourceScheme == gxkb18 && !(resourcePath =~ /\\/Table\\//) && genexus.activePart != Rules"
        },
        {
          "command": "nexus-ide.switchPart.Rules.active",
          "group": "navigation@3",
          "when": "resourceScheme == gxkb18 && !(resourcePath =~ /\\/Table\\//) && genexus.activePart == Rules"
        },
        {
          "command": "nexus-ide.switchPart.Events",
          "group": "navigation@4",
          "when": "resourceScheme == gxkb18 && resourcePath =~ /\\/(WebPanel|Transaction|SDPanel)\\// && genexus.activePart != Events"
        },
        {
          "command": "nexus-ide.switchPart.Events.active",
          "group": "navigation@4",
          "when": "resourceScheme == gxkb18 && resourcePath =~ /\\/(WebPanel|Transaction|SDPanel)\\// && genexus.activePart == Events"
        },
        {
          "command": "nexus-ide.switchPart.Variables",
          "group": "navigation@5",
          "when": "resourceScheme == gxkb18 && !(resourcePath =~ /\\/Table\\//) && genexus.activePart != Variables"
        },
        {
          "command": "nexus-ide.switchPart.Variables.active",
          "group": "navigation@5",
          "when": "resourceScheme == gxkb18 && !(resourcePath =~ /\\/Table\\//) && genexus.activePart == Variables"
        },
        {
          "command": "nexus-ide.switchPart.Layout",
          "group": "navigation@6",
          "when": "resourceScheme == gxkb18 && resourcePath =~ /\\/(WebPanel|Transaction|SDPanel)\\// && genexus.activePart != Layout"
        },
        {
          "command": "nexus-ide.switchPart.Layout.active",
          "group": "navigation@6",
          "when": "resourceScheme == gxkb18 && resourcePath =~ /\\/(WebPanel|Transaction|SDPanel)\\// && genexus.activePart == Layout"
        },
        {
          "command": "nexus-ide.switchPart.Indexes",
          "group": "navigation@7",
          "when": "resourceScheme == gxkb18 && resourcePath =~ /\\/(Transaction|Table)\\// && genexus.activePart != Indexes"
        },
        {
          "command": "nexus-ide.switchPart.Indexes.active",
          "group": "navigation@7",
          "when": "resourceScheme == gxkb18 && resourcePath =~ /\\/(Transaction|Table)\\// && genexus.activePart == Indexes"
        }
      ]
    },
    "configuration": {
      "title": "GeneXus Nexus IDE",
      "properties": {
        "genexus.kbPath": {
          "type": "string",
          "default": "",
          "description": "Path to the GeneXus Knowledge Base."
        },
        "genexus.installationPath": {
          "type": "string",
          "default": "C:\\Program Files (x86)\\GeneXus\\GeneXus18",
          "description": "Path to the GeneXus 18 installation directory."
        },
        "genexus.mcpPort": {
          "type": "number",
          "default": 5000,
          "description": "Port where the MCP Gateway will run."
        },
        "genexus.autoStartBackend": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the MCP backend when the extension activates."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.35",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^8.54.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "typescript": "^5.3.2"
  }
}
